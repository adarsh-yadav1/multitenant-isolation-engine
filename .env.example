# ─────────────────────────────────────────────────────────────────────────────
# Multi-Tenant Resource Isolation Engine — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Master database (tenant registry) ─────────────────────────────────────────
MASTER_DB_ROOT_PASSWORD=change_me_root_master
MASTER_DB_NAME=saas_master
MASTER_DB_USER=master_user
MASTER_DB_PASSWORD=change_me_master_pass

# ── Tenant databases ───────────────────────────────────────────────────────────
TENANT_DB_ROOT_PASSWORD=change_me_root_tenant
TENANT_DB_USER=tenant_user
TENANT_DB_PASSWORD=change_me_tenant_pass

# ── Redis ──────────────────────────────────────────────────────────────────────
# For production Redis with auth:
# REDIS_PASSWORD=change_me_redis_pass

# ── JWT Secrets ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_64_char_base64_secret_for_tenant_jwts
ADMIN_JWT_SECRET=replace_with_different_64_char_base64_secret_for_admin_jwts

# ── Database password encryption ───────────────────────────────────────────────
# 32-byte key for AES-256 encryption of tenant DB credentials stored in master DB
# Generate with: openssl rand -base64 32
DB_ENCRYPTION_KEY=replace_with_32_char_base64_aes256_key

# ── Optional: Observability ────────────────────────────────────────────────────
# SENTRY_DSN=
# DATADOG_API_KEY=
